# Server Configuration
PORT=5000
NODE_ENV=production

# Database - Use your actual MongoDB Atlas connection
MONGODB_URI=mongodb+srv://pos:posd98@pos.8iiiieg.mongodb.net/restaurant-pos?retryWrites=true&w=majority&appName=POS

# Redis (optional - can comment out if not using)
# REDIS_URL=redis://localhost:6379

# JWT - Use strong random strings in production
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# Client URL - Your Render backend URL
CLIENT_URL=https://server-uvyi.onrender.com

# Email Configuration (update with your email service)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
EMAIL_FROM=noreply@restropos.com

# Payment Gateways
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret
RAZORPAY_KEY_ID=rzp_live_RISrpAntWBQZ7c
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Aggregator APIs
ZOMATO_API_URL=https://api.zomato.com/v1
ZOMATO_API_KEY=your_zomato_api_key
ZOMATO_WEBHOOK_SECRET=your_zomato_webhook_secret

SWIGGY_API_URL=https://api.swiggy.com/v1
SWIGGY_API_KEY=your_swiggy_api_key
SWIGGY_WEBHOOK_SECRET=your_swiggy_webhook_secret

UBER_EATS_API_URL=https://api.ubereats.com/v1
UBER_EATS_API_KEY=your_ubereats_api_key
UBER_EATS_WEBHOOK_SECRET=your_ubereats_webhook_secret

# Cloud Storage (for images)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# AWS S3 (alternative - comment out if not using)
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret
# AWS_REGION=us-east-1
# AWS_BUCKET_NAME=restropos-uploads

# Twilio for SMS (comment out if not using)
# TWILIO_ACCOUNT_SID=your_twilio_sid
# TWILIO_AUTH_TOKEN=your_twilio_token
# TWILIO_PHONE_NUMBER=+1234567890

# Google APIs
GOOGLE_MAPS_API_KEY=your_google_maps_key
GOOGLE_ANALYTICS_ID=UA-XXXXX-Y

# Hardware Configuration (for local deployment only)
RECEIPT_PRINTER_NAME=POS-80
KITCHEN_PRINTER_NAME=KITCHEN-80
CASH_DRAWER_PORT=COM3
BARCODE_SCANNER_PORT=COM4

# Security
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100
BCRYPT_ROUNDS=10

# Logging
LOG_LEVEL=debug
LOG_DIR=./logs

# File Upload
MAX_FILE_SIZE=5242880 # 5MB
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# Offline Sync
SYNC_INTERVAL=30000 # 30 seconds
MAX_SYNC_RETRIES=5
CONFLICT_RESOLUTION=server-wins # server-wins, client-wins, manual

# Cache
CACHE_TTL=3600 # 1 hour
REDIS_ENABLED=true

# Feature Flags
ENABLE_OFFLINE_MODE=true
ENABLE_BIOMETRIC=false
ENABLE_KDS=true
ENABLE_AGGREGATOR_INTEGRATION=true
ENABLE_LOYALTY_PROGRAM=true
ENABLE_GIFT_CARDS=true
ENABLE_MULTI_LOCATION=true

# Demo Mode
DEMO_MODE=false
DEMO_USER_EMAIL=demo@restropos.com
DEMO_USER_PASSWORD=demo123
